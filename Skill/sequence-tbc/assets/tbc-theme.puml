' ============================================================
'  TBC THEME — วางบล็อกนี้ "บนสุด" ของทุกไดอะแกรม (หลัง @startuml)
'  วางแบบ inline เท่านั้น ห้ามใช้ !include  (ให้ไฟล์ standalone แชร์ได้)
' ============================================================
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam roundcorner 8
skinparam dpi 150
skinparam sequenceMessageAlign center
skinparam responseMessageBelowArrow true
skinparam maxMessageSize 240
skinparam wrapWidth 240

skinparam sequence {
  ArrowColor #2C3E50
  ArrowFontColor #2C3E50
  LifeLineBorderColor #B0BEC5
  LifeLineBackgroundColor #ECEFF1
  ParticipantBorderColor #34495E
  ParticipantBackgroundColor #ECEFF1
  ParticipantFontColor #1A2530
  ParticipantFontStyle bold
  ActorBorderColor #34495E
  ActorBackgroundColor #FFFFFF
  ActorFontColor #1A2530
  GroupBackgroundColor #E3E9F0
  GroupBorderColor #34495E
  GroupHeaderFontColor #1A2530
  DividerBackgroundColor #34495E
  DividerFontColor #FFFFFF
  LifeLineBorderThickness 1
}

' ---------- ความหมายของสี (ใช้กับ note over User เพื่อบอก Status) ----------
'  #FFF3CD  = รอ / กำลังดำเนินการ        (Pending / In progress)
'  #D4EDDA  = สำเร็จ / อนุมัติ            (Success / Approved)
'  #F8D7DA  = ผิดพลาด / ปฏิเสธ / หมดอายุ  (Error / Rejected / Expired)
'  #D1ECF1  = ข้อมูล / แจ้งเตือนทั่วไป     (Info / Notification)
' --------------------------------------------------------------------------
